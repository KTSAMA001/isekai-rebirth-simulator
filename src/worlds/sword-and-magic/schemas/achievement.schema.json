{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "achievement",
  "type": "object",
  "required": ["id", "name", "description", "icon", "hidden", "condition", "category"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "icon": { "type": "string" },
    "hidden": { "type": "boolean" },
    "condition": { "type": "string" },
    "category": { "type": "string" },
    "reward": { "type": "string" }
  }
}
